{
  "name": "Simulador de Telemetria",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "Simulador_Comercial.py"
      ]
    },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "python -m pip install --upgrade pip && pip install -r requirements-dev.txt",
  "postAttachCommand": "streamlit run Simulador_Comercial.py --server.headless true",
  "portsAttributes": {
    "8501": {
      "label": "Simulador de Telemetria",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [8501]
}
